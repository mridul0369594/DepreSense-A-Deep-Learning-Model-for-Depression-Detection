# ── Firebase Configuration ──────────────────────────────────
# Absolute or relative path to the Firebase service-account JSON key
FIREBASE_CREDENTIALS_PATH=config/firebase-service-account.json

# Firebase Web API key (found in Firebase Console > Project Settings)
FIREBASE_API_KEY=your-firebase-web-api-key-here

# ── Model Configuration ────────────────────────────────────
# Path to the trained model directory (relative to project root)
MODEL_PATH=../output/model

# Path to the SHAP background data file
SHAP_BG_PATH=../output/assets/shap_bg_ec.npy

# ── CORS Configuration ─────────────────────────────────────
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Application Settings ───────────────────────────────────
# Enable debug mode (true / false)
DEBUG=true

# Host and port the server listens on
HOST=0.0.0.0
PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── File Upload Settings ───────────────────────────────────
# Maximum allowed upload size in megabytes
MAX_FILE_SIZE_MB=50

# Directory where uploaded .edf files are temporarily stored
UPLOAD_DIR=uploads

# ── Email / SMTP Configuration ─────────────────────────────
# Gmail App Password recommended. Do NOT use your account password.
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# ── OTP Configuration ──────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
